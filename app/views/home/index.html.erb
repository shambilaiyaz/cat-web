<!-- ct — index view -->
<!--All links red cursive and bold -->
<div id="ful-page">
  <main class="ct-container">

    <!-- Hero Section -->
    <header class="card card-hero">
      <h1 id="welcom" aria-label="Welcome"><span class="sr-only">Loading...</span></h1>
      <h1 id="cat">cats!</h1>
      <img
        src="https://cdn.kastatic.org/third_party/javascript-khansrc/live-editor/build/images/animals/cat.png"
        width="425"
        alt="ct tree img"
      >
      <span id="wild">wild cat!</span>
    </header>

    <!-- Email Signup -->
    <section class="card card-email" aria-label="Email signup">
      <h3 class="card-email-title">🐾 get cat updates!</h3>
      <p class="card-email-sub">leave your email and we'll keep you posted</p>
      <%= form_with model: UserEmail.new, url: user_emails_path, local: false, class: "email-form", html: { data: { turbo: "false" } } do |f| %>
        <%= f.hidden_field :username, id: "email-username" %>
        <div class="email-form-row">
          <%= f.email_field :email, placeholder: "your email...", autocomplete: "email", id: "email-input", required: true %>
          <%= f.submit "sv 🐾", class: "email-submit-btn" %>
        </div>
        <p id="email-msg"></p>
      <% end %>
    </section>

    <!-- Note Input -->
    <section class="card card-note" aria-label="Note input">
      <div id="note">
        <form method="post" onsubmit="return false;">
          <label for="note-input" class="sr-only">Write a note</label>
          <input id="note-input" placeholder="note somthing your looking..." autocomplete="off">
        </form>
      </div>
    </section>

    <!-- Actions Toolbar -->
    <nav class="card card-actions" aria-label="Page actions">
      <!-- boottin !-->
      <button id="ton" aria-label="Ton action">ton</button>
      <!-- sound -->
      <button id="reader" aria-label="Read aloud">read for me</button>
      <button id="help" aria-label="Help">?</button>
    </nav>

    <!-- Facts Section -->
    <section class="card card-facts" aria-label="Cat facts">
      <h2 id="blue">
        cats like to be <span id="nit">clean</span> and act at their own
        style. <br>
        they like to discover about <em>wigly</em> things.
      </h2>
      <!--researched line -->
      <h2 id="green">cats hate green</h2>
    </section>

    <!-- Toy Selector -->
    <section class="card card-toy" aria-label="Toy selector">
      <!-- opti !-->
      <label for="opti" class="sr-only">Choose a toy</label>
      <select id="opti">
        <option id="rope" value="rope">rope</option>
        <option id="rat" value="rat">rat</option>
        <option id="bird" value="bird">feather</option>
        <option id="laser" value="laser">laser</option>
      </select>
      <!--img-->
      <img
        src="https://imgs.search.brave.com/MFR2dtplD4WReIGtOCbt0FSAQYT9WRp_ShFvOXDgTqA/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9pbWFn/ZXMucGV4ZWxzLmNv/bS9waG90b3MvMTQw/NDU1NjIvcGV4ZWxz/LXBob3RvLTE0MDQ1/NTYyLmpwZWc_YXV0/bz1jb21wcmVzcyZj/cz10aW55c3JnYiZk/cHI9MSZ3PTUwMA"
        alt="rope"
        id="img_opti"
        width="380"
      >
    </section>

    <!-- Links -->
    <section class="card card-links" aria-label="External links">
      <!-- link -->
      <a href="https://www.britannica.com/animal/cat"><span id="history">cats history</span></a>
      <!-- link -->
      <a href="https://en.wikipedia.org/wiki/Wildlife"><span id="plant">Wildness</span></a>
    </section>

    <!-- Warnings -->
    <section class="card card-warnings" aria-label="Warnings">
      <h2 class="warning">remember</h2>
      <h2 class="warning">
        don't try to surround your cat when their not happy
      </h2>
      <h2 class="warning">or else they will pee on you</h2>
    </section>

    <!-- Power Command -->
    <footer class="card card-power" aria-label="Power command">
      <!-- power command -->
      <div id="power-box">
        <label for="power-input" class="sr-only">Power command input</label>
        <input
          type="text"
          id="power-input"
          autocomplete="off"
          placeholder="man for manuall | comment <text> | comments | commit save"
        >
        <button id="power-btn">run</button>
        <p id="power-output"></p>
      </div>
    </footer>

    <!-- Logout -->
    <footer class="card-footer-logout">
      <a href="/" id="logout-link">logout</a>
    </footer>

  </main>
</div>

<script nonce="<%= request.content_security_policy_nonce %>">
    // Greet the user by name from sessionStorage (set during login)
    (function() {
        let username = sessionStorage.getItem("ct_username");
        let welcom = document.getElementById("welcom");
        if (username && welcom) {
            welcom.textContent = "learn about cat! " + username + "!";
        } else {
            // Not logged in — redirect back to login
            // window.location.href = "/login";
        }

        // Fill hidden email-username field so it gets submitted with the form
        // Fill hidden email-username field and init email form (see email-ct.js)
        fillEmailUsername(username);
        initEmailForm();

        // Initialize the power commit system
        initPower();
    })();
</script>
<!-- /ct -->
